{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-implementation-before-approval.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-spec-before-status-change.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./**/.env)",
      "Edit(./.env)",
      "Bash(cat .env)",
      "Bash(cat ./.env)"
    ]
  }
}
