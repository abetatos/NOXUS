@article{li_zheng_2023,
  author  = {Li, Hui and Zheng, Bo},
  title   = {{TROPOMI} {NO2} Shows a Fast Recovery of China's Economy in the First Quarter of 2023},
  journal = {Environmental Science \& Technology Letters},
  year    = {2023},
  volume  = {10},
  number  = {8},
  pages   = {635--641},
  doi     = {10.1021/acs.estlett.3c00386},
  note    = {Paywalled (ACS). Supporting Information is open (CC BY-NC 4.0) at figshare DOI 10.1021/acs.estlett.3c00386.s001. NO2-based nowcast of China's post-Chinese-New-Year economic rebound, with meteorology removed via chemical-transport-model simulation -- the same activity-signal logic NOXUS applies at cluster scale.}
}

@article{li_2024_nox_trends,
  author  = {Li, Hui and Zheng, Bo and Lei, Yu and Hauglustaine, Didier and Chen, Cuihong and Lin, Xin and Zhang, Yi and Zhang, Qiang and He, Kebin},
  title   = {Trends and drivers of anthropogenic {NOx} emissions in China since 2020},
  journal = {Environmental Science and Ecotechnology},
  year    = {2024},
  volume  = {21},
  pages   = {100425},
  doi     = {10.1016/j.ese.2024.100425},
  note    = {Open access. Same group as li_zheng_2023; decomposes China's NOx changes since 2020 into economic-activity vs. emission-control vs. meteorological drivers -- directly relevant to separating the activity signal from policy curtailments (a core NOXUS confounder).}
}

@article{mao_2025_ukraine,
  author  = {Mao, Yawen and Ju, Weimin and Wang, Hengmao and Liu, Lei and Wang, Hua and Feng, Shuzhuang and Jia, Mengwei and Jiang, Fei},
  title   = {Inversion-based assessment of anthropogenic {NOx} emission changes in Ukraine during the 2022--2023 war using {TROPOMI} satellite data},
  journal = {Atmospheric Chemistry and Physics},
  year    = {2025},
  volume  = {25},
  pages   = {14187--14204},
  doi     = {10.5194/acp-25-14187-2025},
  note    = {Open access. TROPOMI NO2 inversion quantifies a war-driven activity/industrial shock (industry emissions -34% in 2022), with regional and sectoral breakdown. Closest published analog to the NOXUS premise -- satellite NO2 as a quantitative read on industrial activity. Supersedes the egusphere preprint egusphere-2024-3672 ("28% drop"); cite this version.}
}

@article{montgomery_holloway_2018,
  author  = {Montgomery, Anthony and Holloway, Tracey},
  title   = {Assessing the relationship between satellite-derived {NO2} and economic growth over the 100 most populous global cities},
  journal = {Journal of Applied Remote Sensing},
  year    = {2018},
  volume  = {12},
  number  = {4},
  pages   = {042607},
  doi     = {10.1117/1.JRS.12.042607},
  note    = {Positive NO2-vs-urban-product link found in 38 of 56 low-income cities; ~36 middle-income cities show no clear relationship -- an environmental-Kuznets pattern. The link is income-dependent, not universal.}
}

@article{morris_zhang_2019,
  author  = {Morris, Stephen D. and Zhang, Junjie},
  title   = {Validating China's Output Data Using Satellite Observations},
  journal = {Macroeconomic Dynamics},
  year    = {2019},
  volume  = {23},
  number  = {8},
  pages   = {3327--3354},
  doi     = {10.1017/S1365100518000056},
  note    = {National-level OMI NO2 used to validate Chinese output/GDP. Closest precedent in intent to NOXUS, which differs by working at single-cluster scale with TROPOMI and as a leading indicator on metals instruments. Often cited as "2018" after its SSRN/online-first version (SSRN 2920650); the journal article is 2019. The DOI given in the source working paper (10.1017/S1365100517001140) does not resolve -- correct DOI is 10.1017/S1365100518000056.}
}

