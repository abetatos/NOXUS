@misc{cds_era5,
  author       = {{Copernicus Climate Change Service (C3S), Climate Data Store}},
  title        = {{ERA5} hourly data on single levels from 1940 to present (\texttt{reanalysis-era5-single-levels})},
  howpublished = {Copernicus Climate Data Store (CDS) API, \url{https://cds.climate.copernicus.eu/}},
  year         = {2026},
  note         = {Meteorology source for NOXUS (NOX-003). Free CDS account + one-time dataset-licence acceptance required; AOI/era/overpass-hour subset fetched server-side via cdsapi (one request per year) into a dated NetCDF snapshot. The anonymous ARCO-ERA5 Zarr store was considered and rejected (chunk-1 layout downloads full global fields per timestep). Accessed 2026-06-13.}
}

