# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environments
.venv/
env/
venv/
ENV/
.env
.envrc

# uv
#   The lockfile IS committed on purpose for reproducibility — do not ignore uv.lock.

# Test / coverage / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Editors
.vscode/
.idea/

# NOXUS — raw Earth-observation downloads are large and reproducible; do NOT commit them.
# Derived series (parquet) under data/derived/ ARE meant to be committed.
data/raw/
*.nc
*.tif
*.tiff
# Rendered verification imagery (generated from downloaded NO2) — do not publish.
data/derived/verification/
# NO2-derived analysis products (cube + interim AOI series, footprint signal, activity index)
# — derived from downloaded data; not published (NOX-003 NFR-004).
data/derived/no2/
# ERA5 reanalysis snapshots (dated NetCDF subsets of the public ARCO-ERA5 store) — reproducible,
# not committed (NOX-003 T12). Also matched by data/raw/ and *.nc above; kept explicit for clarity.
data/raw/era5/
# Downloaded archives (e.g. the GEM Global Iron & Steel Tracker zip) — never commit.
*.zip

# Literature PDFs — kept locally for reading, NOT redistributed (publisher copyright).
# The bibliography (literature/references.bib) and literature/README.md ARE committed.
literature/papers/
# Text extracted from those PDFs (for source verification) — same copyright, keep local.
literature/extracted/
