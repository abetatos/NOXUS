# NOXUS credentials — copy to .env and fill in. All sources are free; some require registration.

# Copernicus Data Space Ecosystem (free account) — for Sentinel-5P/TROPOMI access.
# https://dataspace.copernicus.eu/
#
# Option A — password grant (your normal account login). This is what NOXUS uses by
# default to mint a short-lived access token from the OpenID token endpoint.
CDSE_USERNAME=
CDSE_PASSWORD=
# Public client id for the password grant; leave as-is unless CDSE instructs otherwise.
CDSE_CLIENT_ID=cdse-public

# Option B — OAuth client credentials (machine-to-machine). Only needed if you create
# a dedicated client in the CDSE dashboard instead of using your account login above.
CDSE_CLIENT_SECRET=

# Copernicus Climate Data Store (free account) — for ERA5 meteorology (NOX-003 meteo normalisation).
# https://cds.climate.copernicus.eu/  → register, then copy your Personal Access Token below and
# accept the licence for "ERA5 hourly data on single levels from 1940 to present".
# CDSAPI_KEY is cdsapi's own env var; CDSAPI_URL defaults to the endpoint below if omitted.
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# Optional: Google Earth Engine project id, if using the GEE TROPOMI mirror (geo extra).
GEE_PROJECT=
